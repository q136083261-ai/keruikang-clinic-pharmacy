{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "keruikang.com"
        }
      ],
      "destination": "https://www.keruikang.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/mobile",
      "destination": "/mobile.html"
    }
  ]
}
